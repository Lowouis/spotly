{
  "name": "spotly",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "dev-turbo": "NODE_OPTIONS='--dns-result-order=ipv4first' next dev --turbo -p 3001",
    "build": "npm run validate-env && prisma generate && next build --no-lint",
    "start": "next start",
    "lint": "eslint .",
    "lint:strict": "eslint . --max-warnings=0",
    "test": "jest",
    "test:mail:send": "SEND_MAIL_SMOKE=1 jest --runInBand services/server/mails/send-all-templates.integration.test.js",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "validate-env": "node scripts/validate-env.mjs",
    "check": "npm run validate-env && npm run test && npm run build",
    "update prisma": "prisma db push",
    "run cron": "node scripts/cron.mjs cycle",
    "run cron:daily": "node scripts/cron.mjs daily",
    "run cron:all": "node scripts/cron.mjs all",
    "erased": "node scripts/clean.mjs",
    "seed": "node scripts/seed.mjs",
    "seed:demo": "node scripts/seed.mjs --with-test-data",
    "seed:ldap": "node scripts/seed-ldap.mjs",
    "seed:prod": "NODE_ENV=production node scripts/seed.mjs --confirm-production",
    "test-db": "node scripts/test-db.mjs"
  },
  "dependencies": {
    "@headlessui/react": "^2.1.10",
    "@heroicons/react": "^2.1.5",
    "@hookform/resolvers": "^3.9.0",
    "@internationalized/date": "^3.8.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.20.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-aria/i18n": "^3.12.3",
    "@tanstack/react-query": "^5.59.20",
    "@tanstack/react-query-devtools": "^5.69.0",
    "autoprefixer": "^10.4.21",
    "bcrypt": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "critters": "^0.0.23",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "express-rate-limit": "^7.5.0",
    "flowbite": "^2.5.2",
    "formidable": "^3.5.2",
    "html-to-text": "^9.0.5",
    "kerberos": "^2.2.2",
    "ldap-authentication": "^4.0.4",
    "ldapjs": "^3.0.7",
    "lucide-react": "^1.12.0",
    "marked": "^15.0.6",
    "next": "^15.5.15",
    "next-auth": "^4.24.14",
    "node-fetch": "^3.3.2",
    "nodemailer": "^7.0.11",
    "react": "^18",
    "react-aria": "^3.35.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^18",
    "react-hook-form": "^7.53.0",
    "react-hot-toast": "^2.4.1",
    "react-icons": "^5.5.0",
    "react-responsive": "^10.0.1",
    "recharts": "^3.8.1",
    "sharp": "^0.33.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "yup": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.15",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "mailparser": "^3.9.8",
    "postcss": "^8.5.12",
    "prisma": "^5.20.0",
    "tailwindcss": "^3.4.1"
  },
  "overrides": {
    "tailwindcss": "^3.4.1"
  }
}
